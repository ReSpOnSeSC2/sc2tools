# Editor/IDE
.idea/
.vscode/

# Stage 12: installer build artifacts (NEVER commit these). The
# installer build script (packaging/build-installer.ps1) stages a
# full duplicate of the source tree under build/stage/, downloads
# the embeddable Python interpreter, and pre-installs every Python
# and Node.js dependency. That can be 350+ MB. Outputs go to dist/.
/build/
/dist/

# Bootstrap downloads that build-installer.ps1 fetches into the
# repo root if BUILD_DIR resolves there for any reason.
/get-pip.py
/python-*-embed-amd64.zip

# Python test / lint cache dirs (created by pytest, mypy, ruff).
.pytest_cache/
.mypy_cache/
.ruff_cache/

# NSIS scratch (rare but possible if makensis crashes mid-build).
nsa*.tmp

# Additional backup patterns discovered during v0.1.0 rewrite.
# *.pre-repair-* are full snapshots of MyOpponentHistory before the
# one-shot data-repair pass. *.pre-*-bak are transient WIP backups
# from in-flight refactors. None of these belong in source control.
**/*.bak
**/*.bak.*
**/*.bak-*
**/*.pre-repair-*
**/*.pre-fsync-bak
**/*.pre-record-fallback-bak
**/*.pre-restore-*
**/*.pre-chrono-fix-*
**/*.pre-chain-counting-*
**/*.pre-stage*
**/*.salvaged.*
**/*.broken-*
**/session.state.json
**/session.state.json.broken-*

# Snapshots from atomic_io's recovery path. These are full copies of
# data files saved BEFORE a recovery (pre-recovery snapshot) or as a
# corruption record (broken). They're large, only useful at the
# moment of the incident, and not meaningful for source control.
**/*.live-broken*
**/*.pre-stripstrays-*
**/*.tmp.promoted-*
**/*.tmp.promoted-from*

# Orphan-recovery output. recover_orphan_history.py writes timestamped
# directories full of per-record .tmp_<uuid>.json fragments while it
# sweeps the on-disk Black Book; individual fragments can grow to
# hundreds of MB on a corrupted history (one such commit was rejected
# by GitHub at 266 MB > 100 MB hard limit). Per-incident output, never
# source-controlled.
**/recovery-orphans-*/
**/data/*.pre-recovery-*
**/.tmp_*.json

# Cross-process file locks (atomic_io / Lock-FileAtomic.ps1). Tiny,
# transient, machine-local; checking them in causes spurious diffs and
# false conflicts on every run.
**/data/.locks/

# Build/install marker files. .python-deps-stamp is touched by the
# bootstrap script after pip install completes; it's a per-machine
# state file, not a source artifact.
**/data/.python-deps-stamp
