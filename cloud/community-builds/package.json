{
  "name": "@sc2tools/community-builds",
  "version": "1.0.0",
  "description": "Shared community database for SC2 custom build definitions.",
  "private": true,
  "main": "index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "jest --runInBand --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "express-rate-limit": "7.5.0",
    "helmet": "8.1.0",
    "mongodb": "6.13.0",
    "pino": "9.6.0",
    "pino-http": "10.4.0",
    "prom-client": "15.1.3"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.14",
    "@types/node": "22.10.5",
    "@types/supertest": "6.0.2",
    "eslint": "9.18.0",
    "globals": "15.14.0",
    "jest": "29.7.0",
    "mongodb-memory-server": "10.1.4",
    "supertest": "7.0.0",
    "typescript": "5.7.3"
  }
}
