{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sc2tools.local/schemas/custom_builds.schema.json",
  "title": "Custom Builds File (v3)",
  "description": "Local cache of user-authored SC2 build definitions. Version 3 shape introduced in Stage 7.5b: rule-based matching (boolean per-rule, all-must-pass) replaces the v2 signature scoring model. tier replaced by skill_level (SC2 ladder leagues). v2 files auto-migrate on first load with a .pre-v3-bak.<ts> backup. The 4 rule types are eval-honest: 'before' / 'not_before' work on any event name (buildings, units, upgrades, morphs); the UI picks an icon based on the name prefix. 'count_max' / 'count_min' count occurrences of a single name.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "builds"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 3
    },
    "builds": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/build"
      }
    }
  },
  "definitions": {
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "race",
        "vs_race",
        "rules",
        "created_at",
        "updated_at",
        "sync_state"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,78}[a-z0-9]$",
          "minLength": 3,
          "maxLength": 80
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "race": {
          "type": "string",
          "enum": [
            "Protoss",
            "Terran",
            "Zerg"
          ]
        },
        "vs_race": {
          "type": "string",
          "enum": [
            "Protoss",
            "Terran",
            "Zerg",
            "Random",
            "Any"
          ]
        },
        "skill_level": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "bronze",
                "silver",
                "gold",
                "platinum",
                "diamond",
                "master",
                "grandmaster"
              ]
            },
            {
              "type": "null"
            }
          ],
          "description": "Recommended SC2 ladder league. null = unspecified."
        },
        "description": {
          "type": "string",
          "maxLength": 2000
        },
        "win_conditions": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "string",
            "maxLength": 280
          }
        },
        "loses_to": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "string",
            "maxLength": 280
          }
        },
        "transitions_into": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "string",
            "maxLength": 280
          }
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "maxItems": 30,
          "items": {
            "$ref": "#/definitions/rule"
          },
          "description": "All rules must pass for a game to match the build."
        },
        "source_replay_id": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 240
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "author": {
          "type": "string",
          "maxLength": 80
        },
        "sync_state": {
          "type": "string",
          "enum": [
            "pending",
            "synced",
            "conflict",
            "deleted"
          ]
        },
        "remote_version": {
          "type": "integer",
          "minimum": 1
        },
        "upvotes": {
          "type": "integer",
          "minimum": 0
        },
        "downvotes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "rule": {
      "oneOf": [
        {
          "$ref": "#/definitions/beforeRule"
        },
        {
          "$ref": "#/definitions/notBeforeRule"
        },
        {
          "$ref": "#/definitions/countMaxRule"
        },
        {
          "$ref": "#/definitions/countMinRule"
        },
        {
          "$ref": "#/definitions/countExactRule"
        }
      ]
    },
    "beforeRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "time_lt"
      ],
      "properties": {
        "type": {
          "const": "before"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^[A-Za-z][A-Za-z0-9]*$"
        },
        "time_lt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1800,
          "description": "Event must occur before this time (seconds)."
        },
        "tol": {
          "type": "integer",
          "minimum": 0,
          "maximum": 60,
          "description": "Optional. If present, |t - time_lt| <= tol (window match). If absent, t <= time_lt (strict before)."
        }
      }
    },
    "notBeforeRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "time_lt"
      ],
      "properties": {
        "type": {
          "const": "not_before"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^[A-Za-z][A-Za-z0-9]*$"
        },
        "time_lt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1800,
          "description": "Event must NOT occur before this time."
        }
      }
    },
    "countMaxRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "count",
        "time_lt"
      ],
      "properties": {
        "type": {
          "const": "count_max"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^[A-Za-z][A-Za-z0-9]*$"
        },
        "count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 200,
          "description": "Pass if count(name occurrences with t < time_lt) <= count."
        },
        "time_lt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1800
        }
      }
    },
    "countMinRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "count",
        "time_lt"
      ],
      "properties": {
        "type": {
          "const": "count_min"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^[A-Za-z][A-Za-z0-9]*$"
        },
        "count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200,
          "description": "Pass if count(name occurrences with t < time_lt) >= count."
        },
        "time_lt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1800
        }
      }
    },
    "countExactRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "count",
        "time_lt"
      ],
      "properties": {
        "type": {
          "const": "count_exact"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^[A-Za-z][A-Za-z0-9]*$"
        },
        "count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 200,
          "description": "Pass if count(name occurrences with t < time_lt) == count exactly."
        },
        "time_lt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1800
        }
      }
    }
  }
}
