{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sc2tools.respondesc2.dev/schemas/config.schema.json",
  "title": "SC2Tools Installation Config",
  "description": "Per-installation settings. Created by the wizard on first run; editable from the SPA settings page.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "paths",
    "macro_engine",
    "build_classifier",
    "stream_overlay"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version. Bump only on breaking changes."
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sc2_install_dir", "replay_folders"],
      "properties": {
        "sc2_install_dir": {
          "type": "string",
          "description": "Filesystem path to the StarCraft II install directory."
        },
        "replay_folders": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 },
          "description": "Folders to watch for new .SC2Replay files."
        }
      }
    },
    "macro_engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled_disciplines", "minimum_game_length_sec", "engine_version"],
      "properties": {
        "enabled_disciplines": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["chrono", "inject", "mule", "supply", "worker_production"]
          },
          "description": "Macro disciplines scored per game."
        },
        "minimum_game_length_sec": {
          "type": "integer",
          "minimum": 0,
          "maximum": 7200,
          "description": "Games shorter than this are excluded from macro aggregations."
        },
        "engine_version": {
          "type": "string",
          "minLength": 1,
          "description": "Macro engine version tag."
        }
      }
    },
    "build_classifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["active_definition_ids", "use_custom_builds", "use_community_shared_builds"],
      "properties": {
        "active_definition_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 },
          "description": "Build IDs from build_definitions.json that the classifier scores against."
        },
        "use_custom_builds": {
          "type": "boolean",
          "description": "When true, custom_builds.json participates in classification."
        },
        "use_community_shared_builds": {
          "type": "boolean",
          "description": "When true, the shared community build database participates."
        }
      }
    },
    "stream_overlay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "twitch_channel", "obs_websocket"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Master switch for the OBS overlay event bus."
        },
        "twitch_channel": {
          "type": ["string", "null"],
          "maxLength": 64,
          "description": "Twitch channel handle. Null disables chat integration."
        },
        "obs_websocket": {
          "type": "object",
          "additionalProperties": false,
          "required": ["host", "port", "password"],
          "properties": {
            "host": { "type": "string", "minLength": 1 },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "password": { "type": ["string", "null"] }
          }
        },
        "pulse_character_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[0-9]+$" },
          "description": "SC2Pulse character ids for live MMR lookups."
        }
      }
    },
    "voice": {
      "type": "object",
      "additionalProperties": false,
      "description": "Web Speech API settings for the scouting voice readout.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Master switch. When false, no speech is produced."
        },
        "volume": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Speech volume 0-1."
        },
        "rate": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 2,
          "description": "Speech rate. 1.0 = normal. 0.85 = deliberate. 1.2 = fast."
        },
        "pitch": {
          "type": "number",
          "minimum": 0,
          "maximum": 2,
          "description": "Speech pitch. 1.0 = neutral."
        },
        "delay_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5000,
          "description": "Milliseconds to wait before speaking after scoutingReport fires."
        },
        "preferred_voice": {
          "type": "string",
          "description": "Exact browser voice name. Empty = auto-select best English voice."
        }
      }
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["opt_in"],
      "properties": {
        "opt_in": {
          "type": "boolean",
          "description": "Opt-in for anonymized usage telemetry."
        }
      }
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "required": ["theme", "default_perspective"],
      "properties": {
        "theme": {
          "type": "string",
          "enum": ["dark", "light"]
        },
        "default_perspective": {
          "type": "string",
          "enum": ["me", "opponent", "both"]
        }
      }
    },
    "identities": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "character_id"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 32 },
          "character_id": { "type": "string", "pattern": "^[1-5]-S2-[0-9]+-[0-9]+$" },
          "account_id": { "type": "string", "pattern": "^[0-9]+$" },
          "region": { "type": "string", "enum": ["us", "eu", "kr", "cn", "sea"] },
          "battle_tag": { "type": "string", "pattern": "^[^#]+#[0-9]+$", "minLength": 3, "maxLength": 64 },
          "pulse_id": { "type": "string", "pattern": "^[0-9]+$" }
        }
      },
      "description": "All Battle.net identities the user owns. One entry per region."
    }
  }
}
