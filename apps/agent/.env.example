# Cloud API endpoint. The agent talks ONLY to this URL.
# Defaults to the production API: https://sc2tools-api.onrender.com
# Uncomment and edit only if you're pointing at a different backend
# (e.g. a local dev API, or your own self-hosted fork).
# SC2TOOLS_API_BASE=http://localhost:8080

# Optional override for the replay folder (auto-detected otherwise).
# SC2TOOLS_REPLAY_FOLDER=

# Where the agent stores its state (pairing token, last-synced cursor).
# Defaults to %LOCALAPPDATA%\sc2tools on Windows, ~/.local/share/sc2tools elsewhere.
# SC2TOOLS_STATE_DIR=

# How often to scan the replay folder when the OS doesn't fire an event
# (fallback for cloud-sync drives like OneDrive). Seconds.
SC2TOOLS_POLL_INTERVAL=10

# How many parallel deep parses. Each replay is ~150-500ms; 1 is plenty
# for one-game-at-a-time live use, raise to 2-3 if you have a backlog.
SC2TOOLS_PARSE_CONCURRENCY=1
