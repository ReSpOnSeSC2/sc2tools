# ---- SC2 Tools cloud API env ----
# Copy this file to .env (never commit .env). Render reads these from
# the dashboard; locally, dotenv loads .env.

# HTTP
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# MongoDB Atlas. Use a separate database from community-builds.
# Atlas connection string:  mongodb+srv://<user>:<pass>@<host>/?...
MONGODB_URI=
MONGODB_DB=sc2tools_saas

# Clerk — server SDK keys, get from https://dashboard.clerk.com → API keys
CLERK_SECRET_KEY=
# Optional: lock JWTs to a known issuer + audience (recommended in prod)
CLERK_JWT_ISSUER=
CLERK_JWT_AUDIENCE=

# 32 random bytes hex-encoded — used to HMAC opponent battle-tags before
# write so cloud DB never stores plaintext PII. Generate with:
#   openssl rand -hex 32
SERVER_PEPPER_HEX=

# CORS — comma-separated list of origins. Include your Vercel URL +
# localhost for dev. Empty = allow all (dev only).
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://sc2tools.app

# How many requests/min/user we allow.
RATE_LIMIT_PER_MINUTE=120
